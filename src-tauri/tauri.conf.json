{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TALLY - Ai Usage Monitor",
  "version": "0.1.56",
  "identifier": "com.cjmedia.tally",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TALLY - Ai Usage Monitor",
        "width": 272,
        "height": 122,
        "minWidth": 240,
        "minHeight": 110,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
